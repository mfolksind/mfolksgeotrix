---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import SelectInput from "@components/ui/forms/input/SelectInput.astro";
import Icon from "@components/ui/icons/Icon.astro";

// Define the variables that will be used in this component
const title: string = "Contact us";
const subTitle: string =
  "Have questions or want to discuss a project? Reach out, and let's craft the perfect protection solution with our experts.";
const formTitle: string = "Submit an Enquiry";
const formSubTitle: string = "Our technical specialists will get back to you within 24 hours.";
---

<!-- Contact Us -->
<section class="relative mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8 border border-neutral-200 dark:border-neutral-700 shadow-sm">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        <!-- Form for user input with various input fields.-->
        <form id="contact-enquiry-form">
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="contact-name"
                label="Full Name"
                name="name"
              />
              <TextInput
                id="contact-company"
                label="Company"
                name="company"
              />
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <EmailContactInput id="contact-email" />
              <PhoneInput id="contact-phone" />
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <SelectInput
                id="contact-product"
                label="Product Required"
                name="product"
                options={[
                  { value: "earthing-rods", label: "Earthing Rods (Chemical/Copper)" },
                  { value: "lightning-arrestors", label: "Lightning Arrestors (ESE/Conventional)" },
                  { value: "earthing-strips", label: "Earthing Strips & Flats" },
                  { value: "bfc-compound", label: "BFC / Backfill Compound" },
                  { value: "maintenance-audit", label: "Maintenance & Audits" },
                  { value: "other-custom", label: "Other / Custom Solution" },
                ]}
              />
              <TextInput
                id="contact-quantity"
                label="Quantity"
                name="quantity"
              />
            </div>
            <TextAreaInput
              id="contact-message"
              label="Message / Project Details"
              name="message"
            />
          </div>

          <div class="mt-4 grid">
          <div class="mt-4 grid">
            <!-- Google reCAPTCHA v2 Widget -->
            {import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ? (
               <div class="g-recaptcha mb-4" data-sitekey={import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY}></div>
            ) : (
               <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400" role="alert">
                  <span class="font-medium">Configuration Warning!</span> reCAPTCHA site key is missing. Form will not work.
               </div>
            )}
            <AuthBtn title="Send Enquiry" />
          </div>

          <div class="mt-3 text-center">
             <div id="form-status" class="hidden text-sm font-bold mb-2"></div>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
      </div>

      <!--ContactIconBlocks are used to display different methods of contacting.-->
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Corporate Office"
          content="MFOLKS Geotrix Private Limited"
          isAddressVisible={true}
          addressContent="10134, Model Basti Industrial Area, East Park Road, Delhi, India - 110005"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Manufacturing Unit"
          content="Plant-I (Copper Bonding)"
          isAddressVisible={true}
          addressContent="Shed No. 12-B, Industrial Hub, Bhiwadi, Rajasthan - 301019"
          ><Icon name="building" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Call or WhatsApp"
          content="Instant technical support for your queries."
          isLinkVisible={true}
          linkTitle="+91 9711826427"
          linkURL="https://wa.me/919711826427"
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Email Support"
          content="For bulk technical quotations and tenders."
          isLinkVisible={true}
          linkTitle="info@mfolks.com"
          linkURL="mailto:info@mfolks.com"
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>

<!-- Import Google reCAPTCHA v2 API -->
<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<script is:inline define:vars={{ 
  WEB_APP_URL: import.meta.env.PUBLIC_GSCRIPT_APP_URL || "", 
  API_KEY: import.meta.env.PUBLIC_GSCRIPT_API_KEY || ""
}}>
  const form = document.getElementById('contact-enquiry-form');
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!statusEl) return;

    if (!WEB_APP_URL || !API_KEY) {
      statusEl.innerText = 'Configuration Error: Missing API configuration.';
      statusEl.classList.remove('hidden');
      statusEl.classList.add('text-red-600');
      console.error('Missing PUBLIC_GSCRIPT_APP_URL or PUBLIC_GSCRIPT_API_KEY');
      return;
    }
    if (!statusEl) return;

    // Reset status
    statusEl.classList.remove('hidden', 'text-green-600', 'text-red-600');
    statusEl.classList.add('text-neutral-500');
    statusEl.innerText = 'Verifying...';
    statusEl.classList.remove('hidden');

    // 1. Verify reCAPTCHA
    let captchaResponse = null;
    if (typeof grecaptcha !== 'undefined') {
       try {
         captchaResponse = grecaptcha.getResponse();
       } catch (err) {
         console.warn('reCAPTCHA not ready or not configured');
       }
    }

    if (!captchaResponse) {
      statusEl.innerText = 'Please complete the reCAPTCHA verification. (If invisible, config is missing)';
      statusEl.classList.replace('text-neutral-500', 'text-red-600');
      statusEl.classList.remove('hidden');
      return;
    }

    statusEl.innerText = 'Sending enquiry...';

    // 2. Prepare Data
    const formData = new FormData(form);
    
    // Combine message and quantity
    const quantity = formData.get('quantity') || '';
    const originalMessage = formData.get('message') || '';
    const fullMessage = quantity ? `${originalMessage}\n\nQuantity: ${quantity}` : originalMessage;

    // Map fields to match Google Apps Script expectations
    const payload = {
      submitted_at: new Date().toISOString(),
      full_name: formData.get('name'),
      email: formData.get('hs-email-contacts'),
      phone: formData.get('hs-phone-number'),
      company_name: formData.get('company'),
      interested_in: formData.get('product'),
      service_product_required: formData.get('product'),
      message: fullMessage,
      source: 'Website – MFolks Form',
      recaptcha_token: captchaResponse // Send token if backend wants to verify later
    };

    try {
      // 3. Send to Google Apps Script
      // We accept opaque response ('no-cors') or try 'text/plain' to avoid preflight
      const response = await fetch(`${WEB_APP_URL}?key=${API_KEY}`, {
        method: 'POST',
        headers: {
            'Content-Type': 'text/plain;charset=utf-8', 
        },
        body: JSON.stringify(payload),
      });

      // Since Google Apps Script returns JSON with success, we can try to parse if CORS allows
      // If we used 'no-cors' mode we wouldn't see the response status.
      // Assuming the script is deployed as "Me" (admin) and access "Anyone", it might handle CORS if run as a Web App correctly.
      // But typically fetch to GAS fails CORS unless text/plain is used (simple request). 
      // Even then, reading response text might fail if no Access-Control-Allow-Origin header is sent by GAS.
      // However, usually plain POST works. Let's assume success if no network error.
      
      const resultText = await response.text();
      let result;
      try {
        result = JSON.parse(resultText);
      } catch (e) {
          // If response is opaque or not JSON, assume success if fetch didn't throw network error
          result = { status: 'success' };
      }

      if (result.status === 'success' || response.ok) {
        statusEl.innerText = 'Success! Your enquiry has been received.';
        statusEl.classList.replace('text-neutral-500', 'text-green-600');
        form.reset();
        grecaptcha.reset();
      } else {
         throw new Error(result.message || 'Submission failed');
      }

    } catch (err) {
      console.error(err);
      // Fallback: if it was a CORS issue but request actually went through (common with GAS),
      // we might want to be optimistic or just show error. 
      // For now, show error.
      statusEl.innerText = 'Error sending enquiry. Please try again or call us.';
      statusEl.classList.replace('text-neutral-500', 'text-red-600');
    }
  });
</script>
