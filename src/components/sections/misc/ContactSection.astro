---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import SelectInput from "@components/ui/forms/input/SelectInput.astro";
import Icon from "@components/ui/icons/Icon.astro";

const title = "Get in Touch";
const subtitle =
  "Partner with India's leading earthing and lightning protection specialists. Our team is ready to support your project.";
---

<!-- Contact Section -->
<section class="relative py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span
        class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold text-orange-600 dark:text-orange-400 bg-orange-100 dark:bg-orange-900/30 rounded-full"
      >
        Contact Us
      </span>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4"
      >
        {title}
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        {subtitle}
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Contact Information Sidebar -->
      <div class="lg:col-span-1 space-y-6">
        <!-- Quick Contact Cards -->
        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm hover:shadow-lg transition-shadow"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center text-orange-600 dark:text-orange-400"
            >
              <Icon name="chatBubble" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Call or WhatsApp
              </h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                Get instant support
              </p>
              <a
                href="https://wa.me/919711826427"
                class="text-orange-600 dark:text-orange-400 font-semibold hover:underline"
              >
                +91 9711826427
              </a>
            </div>
          </div>
        </div>

        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm hover:shadow-lg transition-shadow"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400"
            >
              <Icon name="envelopeOpen" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Email Us
              </h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                For quotations & tenders
              </p>
              <a
                href="mailto:info@mfolks.com"
                class="text-blue-600 dark:text-blue-400 font-semibold hover:underline break-all"
              >
                info@mfolks.com
              </a>
            </div>
          </div>
        </div>

        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-green-600 dark:text-green-400"
            >
              <Icon name="mapPin" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Corporate Office Address:
              </h3>
              <p
                class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
              >
                
                801–802, 8th Floor, KLJ Tower<br />
                Pitam Pura, Netaji Subhash Place<br />
                Delhi – 110034, India
              </p>
            </div>
          </div>
        </div>

        <div
          class="bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl p-6 text-white"
        >
          <h3 class="font-bold text-lg mb-2">Business Hours</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-orange-100">Monday - Saturday</span>
              <span class="font-semibold">9:00 AM - 6:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="text-orange-100">Sunday</span>
              <span class="font-semibold">Closed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-8 lg:p-10 border border-neutral-200 dark:border-neutral-700 shadow-lg"
        >
          <div class="mb-8">
            <h2
              class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-2"
            >
              Send Us an Enquiry
            </h2>
            <p class="text-neutral-600 dark:text-neutral-400">
              Fill out the form below and our technical team will respond within
              24 hours.
            </p>
          </div>

          <form id="contact-enquiry-form" class="space-y-6">
            <!-- Personal Details -->
            <div class="space-y-4">
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >1</span
                >
                Personal Information
              </h3>

              <TextInput id="contact-name" label="Full Name" name="name" />

              <div class="grid sm:grid-cols-2 gap-4">
                <EmailContactInput id="contact-email" />
                <PhoneInput id="contact-phone" />
              </div>
            </div>

            <!-- Company Details -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >2</span
                >
                Company Information
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <TextInput
                  id="contact-company"
                  label="Company Name"
                  name="company"
                />
                <SelectInput
                  id="contact-company-type"
                  label="Company Type"
                  name="company_type"
                  options={[
                    { value: "", label: "Select type" },
                    { value: "epc-contractor", label: "EPC Contractor" },
                    { value: "manufacturer", label: "Manufacturer" },
                    { value: "distributor", label: "Distributor / Dealer" },
                    { value: "end-user", label: "End User / Project Owner" },
                    { value: "consultant", label: "Consultant / Engineer" },
                    { value: "government", label: "Government / PSU" },
                    { value: "other", label: "Other" },
                  ]}
                />
              </div>
            </div>

            <!-- Location -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >3</span
                >
                Project Location
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <TextInput id="contact-city" label="City" name="city" />
                <TextInput
                  id="contact-state"
                  label="State / Province"
                  name="state"
                />
              </div>

              <div>
                <SelectInput
                  id="contact-country"
                  label="Country"
                  name="country"
                  options={[
                    { value: "", label: "Select country" },
                    { value: "IN", label: "India" },
                    { value: "AE", label: "UAE" },
                    { value: "SA", label: "Saudi Arabia" },
                    { value: "QA", label: "Qatar" },
                    { value: "OM", label: "Oman" },
                    { value: "BD", label: "Bangladesh" },
                    { value: "LK", label: "Sri Lanka" },
                    { value: "NP", label: "Nepal" },
                    { value: "OTHER", label: "Other" },
                  ]}
                />
                <input
                  type="text"
                  id="contact-country-other"
                  name="country_other"
                  placeholder="Please specify country"
                  class="hidden mt-2 block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 placeholder:text-neutral-500 focus:border-orange-500 focus:outline-hidden focus:ring-2 focus:ring-orange-500/20 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:placeholder:text-neutral-400"
                />
              </div>
            </div>

            <!-- Requirements -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >4</span
                >
                Project Requirements
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <SelectInput
                  id="contact-product"
                  label="Product / Service Required"
                  name="product"
                  options={[
                    { value: "", label: "Select product/service" },
                    {
                      value: "earthing-rods",
                      label: "Earthing Rods (Chemical/Copper)",
                    },
                    {
                      value: "lightning-arrestors",
                      label: "Lightning Arrestors (ESE/Conventional)",
                    },
                    {
                      value: "earthing-strips",
                      label: "Earthing Strips & Flats",
                    },
                    { value: "bfc-compound", label: "BFC / Backfill Compound" },
                    {
                      value: "maintenance-audit",
                      label: "Maintenance & Audits",
                    },
                    {
                      value: "turnkey-solution",
                      label: "Turnkey Earthing Solution",
                    },
                    { value: "other-custom", label: "Other / Custom Solution" },
                  ]}
                />
                <TextInput
                  id="contact-quantity"
                  label="Estimated Quantity (Optional)"
                  name="quantity"
                />
              </div>

              <TextAreaInput
                id="contact-message"
                label="Project Details / Special Requirements"
                name="message"
              />
            </div>

            <!-- reCAPTCHA & Submit -->
            <div class="pt-6 space-y-4">
              {
                import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ? (
                  <div
                    class="g-recaptcha"
                    data-sitekey={import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY}
                  />
                ) : (
                  <div
                    class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/20 dark:text-red-400"
                    role="alert"
                  >
                    <span class="font-medium">Configuration Warning:</span>{" "}
                    reCAPTCHA site key is missing.
                  </div>
                )
              }

              <div id="form-status" class="hidden text-sm font-semibold"></div>

              <AuthBtn title="Send Enquiry" />

              <p
                class="text-xs text-center text-neutral-500 dark:text-neutral-400"
              >
                By submitting this form, you agree to our privacy policy. We'll
                respond within 24 hours.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Load reCAPTCHA Script -->
<script is:inline src="https://www.google.com/recaptcha/api.js" async defer
></script>

<!-- Form Handler Script -->
<script
  define:vars={{
    WEB_APP_URL: import.meta.env.PUBLIC_GSCRIPT_APP_URL || "",
    API_KEY: import.meta.env.PUBLIC_GSCRIPT_API_KEY || "",
    IS_DEV: import.meta.env.DEV,
  }}
>
  const form = document.getElementById("contact-enquiry-form");
  const statusEl = document.getElementById("form-status");
  const countrySelect = document.getElementById("contact-country");
  const countryOtherInput = document.getElementById("contact-country-other");

  // Show/hide custom country input
  countrySelect?.addEventListener("change", (e) => {
    if (e.target.value === "OTHER") {
      countryOtherInput?.classList.remove("hidden");
    } else {
      countryOtherInput?.classList.add("hidden");
      countryOtherInput.value = "";
    }
  });

  // Form submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!statusEl) return;

    // Reset status
    statusEl.classList.remove(
      "text-green-600",
      "text-red-600",
      "text-neutral-500",
    );
    statusEl.classList.add("text-neutral-500");
    statusEl.classList.remove("hidden");
    statusEl.innerText = "";

    // Validate configuration
    if (!WEB_APP_URL || !API_KEY) {
      statusEl.innerText =
        "⚠️ Configuration error. Please contact us directly.";
      statusEl.classList.replace("text-neutral-500", "text-red-600");
      return;
    }

    // Verify reCAPTCHA
    let captchaResponse = "";
    if (IS_DEV) {
      console.log("Dev Mode: Bypassing reCAPTCHA");
      captchaResponse = "dev_mode_bypass";
    } else {
      if (typeof grecaptcha !== "undefined") {
        try {
          captchaResponse = grecaptcha.getResponse();
        } catch (err) {
          console.warn("reCAPTCHA not ready");
        }
      }

      if (!captchaResponse) {
        statusEl.innerText = "⚠️ Please complete the reCAPTCHA verification.";
        statusEl.classList.replace("text-neutral-500", "text-red-600");
        return;
      }
    }

    statusEl.innerText = "⏳ Sending your enquiry...";

    // Prepare data
    const formData = new FormData(form);

    // Get cart data
    let cartContent = "";
    try {
      const savedCart = localStorage.getItem("mfolks_cart");
      if (savedCart) {
        const cartItems = JSON.parse(savedCart);
        if (Array.isArray(cartItems) && cartItems.length > 0) {
          cartContent =
            "\n\n--- CART ITEMS ---\n" +
            cartItems
              .map(
                (item) =>
                  `- ${item.productName} (${item.variant?.label || "Default"})\n  Quantity: ${item.quantity} ${item.priceUnit || ""}`,
              )
              .join("\n");
        }
      }
    } catch (e) {
      console.error("Error reading cart", e);
    }

    // Build message
    const quantity = formData.get("quantity") || "";
    const originalMessage = formData.get("message") || "";
    let fullMessage = originalMessage;
    if (quantity) fullMessage += `\n\nQuantity: ${quantity}`;
    if (cartContent) fullMessage += cartContent;

    // Handle custom country
    const selectedCountry = formData.get("country");
    const customCountry = formData.get("country_other");
    const finalCountry =
      selectedCountry === "OTHER" ? customCountry : selectedCountry;

    const selectedCountryCode = formData.get("country_code");
    const customCountryCode = formData.get("country_code_other");
    const finalCountryCode =
      selectedCountryCode === "OTHER" ? customCountryCode : selectedCountryCode;

    // Build payload
    const payload = {
      submitted_at: new Date().toISOString(),
      full_name: formData.get("name"),
      email: formData.get("hs-email-contacts"),
      country_code: finalCountryCode || "",
      phone: formData.get("hs-phone-number"),
      company_name: formData.get("company"),
      interested_in: formData.get("product"),
      company_type: formData.get("company_type") || "",
      service_product_required: formData.get("product"),
      country: finalCountry || "",
      state: formData.get("state") || "",
      city: formData.get("city") || "",
      message: fullMessage,
      source: "MFolks Geotrix Site",
      recaptcha_token: captchaResponse,
    };

    try {
      const response = await fetch(`${WEB_APP_URL}?key=${API_KEY}`, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(payload),
      });

      const resultText = await response.text();
      let result;
      try {
        result = JSON.parse(resultText);
      } catch (e) {
        result = { status: "success" };
      }

      if (result.status === "success" || response.ok) {
        statusEl.innerText =
          "✅ Success! Your enquiry has been received. We'll respond within 24 hours.";
        statusEl.classList.replace("text-neutral-500", "text-green-600");
        form.reset();
        if (!IS_DEV && typeof grecaptcha !== "undefined") grecaptcha.reset();
      } else {
        throw new Error(result.message || "Submission failed");
      }
    } catch (err) {
      console.error(err);
      statusEl.innerText =
        "❌ Error sending enquiry. Please try again or call us directly.";
      statusEl.classList.replace("text-neutral-500", "text-red-600");
    }
  });
</script>
