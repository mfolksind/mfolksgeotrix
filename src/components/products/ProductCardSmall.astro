---
// Product card for WordPress data - Small variant
const { product } = Astro.props;

const imageUrl = product.featuredImage?.node?.sourceUrl || '/placeholder-product.jpg';
const categoryName = product.productCategories?.nodes?.[0]?.name || 'Product';
---

<a
  href={`/${product.slug}`}
  class="group relative block overflow-hidden rounded-xl border border-neutral-200 transition-all duration-300 hover:border-orange-400 hover:shadow-xl dark:border-neutral-700 dark:hover:border-orange-300"
>
  <div class="aspect-square overflow-hidden bg-neutral-100 dark:bg-neutral-800">
    <img
      src={imageUrl}
      alt={product.title}
      class="h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-4">
    <p class="text-xs font-medium uppercase tracking-wide text-orange-400 dark:text-orange-300">
      {categoryName}
    </p>
    <h3 class="mt-1 text-lg font-bold text-neutral-800 dark:text-neutral-200">
      {product.title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm text-neutral-600 dark:text-neutral-400">
      {product.productData?.shortDescription || ''}
    </p>
    <div class="mt-4 flex items-center text-sm font-medium text-orange-400 dark:text-orange-300">
      View Details
      <svg
        class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
    </div>
  </div>
</a>
