---
import ProductCard from "./ProductCard.astro";

interface Props {
    products: any[];
    variant?: "orange" | "blue" | "green";
    title: string;
    icon?: string;
    badge?: string;
    ctaText?: string;
    showGlow?: boolean;
}

const {
    products,
    variant = "orange",
    title,
    icon,
    badge,
    ctaText,
    showGlow = false,
} = Astro.props;

// Color mappings for scrollbar
const scrollbarColors = {
    orange: "rgb(249 115 22)",
    blue: "rgb(59 130 246)",
    green: "rgb(34 197 94)",
};

// Icon color classes
const iconColors = {
    orange: "text-orange-500",
    blue: "text-blue-500",
    green: "text-green-500",
};
---

{
    products && products.length > 0 && (
        <div class="space-y-6">
            <div class="flex items-center gap-3">
                {icon && (
                    <svg
                        class={`w-6 h-6 ${iconColors[variant]}`}
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        set:html={icon}
                    />
                )}
                <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100">
                    {title}
                </h2>
            </div>
            <div
                class="overflow-x-auto pb-4 -mx-4 px-4"
                style={`scrollbar-width: thin; scrollbar-color: ${scrollbarColors[variant]} transparent;`}
            >
                <div class="flex gap-4" style="min-width: min-content;">
                    {products.map((product: any) => (
                        <ProductCard
                            product={product}
                            variant={variant}
                            badge={badge}
                            ctaText={ctaText}
                            showGlow={showGlow}
                        />
                    ))}
                </div>
            </div>
        </div>
    )
}
