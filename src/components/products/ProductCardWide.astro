---
// Product card for WordPress data - Wide variant
const { product } = Astro.props;

const imageUrl = product.featuredImage?.node?.sourceUrl || '/placeholder-product.jpg';
const categoryName = product.productCategories?.nodes?.[0]?.name || 'Product';
---

<a
  href={`/${product.slug}`}
  class="group relative col-span-1 overflow-hidden rounded-xl border border-neutral-200 transition-all duration-300 hover:border-orange-400 hover:shadow-xl sm:col-span-2 dark:border-neutral-700 dark:hover:border-orange-300"
>
  <div class="grid gap-4 sm:grid-cols-2">
    <div class="aspect-square overflow-hidden bg-neutral-100 sm:aspect-auto dark:bg-neutral-800">
      <img
        src={imageUrl}
        alt={product.title}
        class="h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="flex flex-col justify-center p-6">
      <p class="text-xs font-medium uppercase tracking-wide text-orange-400 dark:text-orange-300">
        {categoryName}
      </p>
      <h3 class="mt-2 text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        {product.title}
      </h3>
      <p class="mt-3 line-clamp-3 text-neutral-600 dark:text-neutral-400">
        {product.productData?.shortDescription || ''}
      </p>
      <div class="mt-6 flex items-center text-sm font-medium text-orange-400 dark:text-orange-300">
        View Details
        <svg
          class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </div>
    </div>
  </div>
</a>
