---
interface Props {
    product: {
        slug: string;
        title: string;
        featuredImage?: {
            node: {
                sourceUrl: string;
                altText?: string;
            };
        };
    };
    variant?: "orange" | "blue" | "green";
    badge?: string;
    ctaText?: string;
    showGlow?: boolean;
}

const {
    product,
    variant = "orange",
    badge = "Product",
    ctaText = "View Details",
    showGlow = false,
} = Astro.props;

// Color mappings
const variantColors = {
    orange: {
        badge: "text-orange-400 dark:text-orange-300",
        border: "hover:border-orange-400 dark:hover:border-orange-300",
        cta: "text-orange-400 dark:text-orange-300",
    },
    blue: {
        badge: "text-blue-400 dark:text-blue-300",
        border: "hover:border-blue-400 dark:hover:border-blue-300",
        cta: "text-blue-400 dark:text-blue-300",
    },
    green: {
        badge: "text-green-400 dark:text-green-300",
        border: "hover:border-green-400 dark:hover:border-green-300",
        cta: "text-green-400 dark:text-green-300",
    },
};

const colors = variantColors[variant];
---

<a
    href={`/${product.slug}`}
    class={`group block overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 transition-all duration-300 hover:shadow-xl ${colors.border} relative`}
    style="flex-shrink: 0; width: 220px;"
>
    {
        showGlow && (
            <div class="absolute -top-2 -right-2 w-16 h-16 bg-gradient-to-br from-green-400 to-green-600 opacity-10 rounded-full blur-2xl group-hover:opacity-20 transition-opacity z-0" />
        )
    }

    <div
        class={`aspect-square overflow-hidden bg-neutral-100 dark:bg-neutral-800 ${showGlow ? "relative z-10" : ""}`}
    >
        {
            product.featuredImage?.node?.sourceUrl ? (
                <img
                    src={product.featuredImage.node.sourceUrl}
                    alt={product.featuredImage.node.altText || product.title}
                    class="h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full flex items-center justify-center">
                    <svg
                        class="w-16 h-16 text-neutral-300 dark:text-neutral-600"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1"
                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                        />
                    </svg>
                </div>
            )
        }
    </div>

    <div class={`p-4 ${showGlow ? "relative z-10" : ""}`}>
        <p
            class={`text-xs font-medium uppercase tracking-wide ${colors.badge}`}
        >
            {badge}
        </p>
        <h3
            class="mt-1 text-base font-bold text-neutral-800 dark:text-neutral-200 line-clamp-2"
        >
            {product.title}
        </h3>
        <div class={`mt-3 flex items-center text-sm font-medium ${colors.cta}`}>
            {ctaText}
            <svg
                class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
            </svg>
        </div>
    </div>
</a>
