---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";

// Import necessary images
import blueprints from "@images/blueprints-image.avif";
import personWorking from "@images/person-working.avif";
import beforeAfter from "@images/before-after.avif";
import constructionWorkers from "@images/construction-workers.avif";
import aerialView from "@images/aerial-view.avif";
import usingTools from "@images/using-tools.avif";
import progressBuilding from "@images/progress-building.avif";
import underConstruction from "@images/under-construction.avif";
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Expert Site Consultation",
    subTitle:
      "Choosing the right protection system begins with understanding your environment. Our experts provide detailed site surveys and soil resistivity tests to ensure your earthing system is perfectly matched to your local conditions, ensuring safety and compliance from day one.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Technical staff reviewing blueprints for earthing systems.",
    imgTwo: personWorking,
    imgTwoAlt: "Technical analysis of soil resistivity data.",
  },
  {
    isRightSection: false,
    title: "Precision Earthing Installation",
    subTitle:
      "Our installation teams are trained to the highest standards, ensuring every technical detail—from chemical electrode placement to backfill compound application—is performed with precision. We bring MFOLKS quality to your site, ensuring systems that last for decades.",
    img: beforeAfter,
    imgAlt: "Progress from excavation to completed earthing pit.",
    btnExists: true,
    btnTitle: "View Installation Steps",
    btnURL: "/quality",
  },
  {
    isRightSection: true,
    title: "Technical Design & Solutions",
    subTitle:
      "Every facility has unique vulnerabilities. We provide customized design services for lightning protection systems, ensuring path optimization and maximum coverage using ESE or conventional terminals based on your risk profile.",
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: "Technical team drafting lightning protection layouts.",
    imgTwo: aerialView,
    imgTwoAlt: "Aerial overview of a protected industrial facility.",
  },
  {
    isRightSection: false,
    title: "Maintenance & System Audits",
    subTitle:
      "Grounding systems are 'hidden' assets. We provide regular maintenance, integrity testing, and certification audits to ensure your protection remains reliable even years after installation, protecting your people and expensive infrastructure.",
    img: usingTools,
    imgAlt: "Technician performing continuity test on an earthing grid.",
  },
  {
    isRightSection: true,
    title: "Industrial & Solar Turnkey Solutions",
    subTitle:
      "For large-scale arrays and factories, we offer full turnkey protection packages. From material supply to final commissioning and documentation, MFOLKS Geotrix is your single-point partner for industrial electrical safety.",
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: "Turnkey installation at a solar power plant.",
    imgTwo: underConstruction,
    imgTwoAlt: "Integrated grounding grid at a new industrial construction.",
    btnExists: true,
    btnTitle: "Request a Consultation",
    btnURL: "/contact-us",
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  "MFOLKS Geotrix provides end-to-end electrical safety services including site surveys, technical design, precision installation, and maintenance for earthing and lightning protection.";
const ogTitle = "Protection Services & Solutions | MFOLKS Geotrix";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/services`,
    url: `${SITE.url}/services`,
    name: "Earthing & Lightning Protection Services | MFOLKS Geotrix",
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
    },
    inLanguage: "en-US",
  }}
>
  <MainSection
    title="Safety Built Into Every Detail"
    subTitle="MFOLKS Geotrix goes beyond manufacturing. We provide the expertise needed to design, install, and maintain systems that stand up to the most demanding industrial environments. Your safety is our benchmark."
    btnExists={true}
    btnTitle="Schedule a Site Survey"
    btnURL="/contact-us"
  />

  {
    articles.map((article) => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt || "Service image"}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt || "Service image"}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt || "Service image"}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Proven Performance"
    subTitle="Our commitment to excellence is proven by the numbers. From small commercial builds to massive solar farms, MFOLKS Geotrix systems provide the reliability you can trust."
    mainStatTitle="500+"
    mainStatSubTitle="successful large-scale industrial & solar installations"
    stats={[
      {
        stat: "100%",
        description: "compliance with IS/IEC standards",
      },
      {
        stat: "25+",
        description: "years of technical expertise",
      },
      {
        stat: "0",
        description: "system failures reported",
      },
    ]}
  />
</MainLayout>
