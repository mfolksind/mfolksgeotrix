---
import MainLayout from "@layouts/MainLayout.astro";
const pageTitle = "Solar Savings Calculator | MFOLKS Geotrix";
const metaDesc =
    "Estimate your solar ROI – system size, savings & payback period for Industrial, Commercial or Residential properties.";
---

<MainLayout title={pageTitle} customDescription={metaDesc}>
    <!-- HERO -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-sky-50 via-white to-cyan-50 dark:from-neutral-800 dark:via-neutral-900 dark:to-neutral-800 pt-28 pb-12 border-b border-neutral-200 dark:border-neutral-700"
    >
        <div
            class="absolute inset-0 opacity-20 pointer-events-none"
            style="background:radial-gradient(ellipse 80% 60% at 60% 0%,#50c1c8,transparent)"
        >
        </div>
        <!-- scattered solar images -->
        <img
            src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=300&q=60&fit=crop"
            alt="solar"
            class="sc-img"
            style="top:12%;left:3%;transform:rotate(-6deg)"
        />
        <img
            src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?w=280&q=60&fit=crop"
            alt="solar"
            class="sc-img"
            style="top:5%;right:4%;transform:rotate(5deg)"
        />
        <img
            src="https://images.unsplash.com/photo-1466611653911-95081537e5b7?w=260&q=60&fit=crop"
            alt="solar"
            class="sc-img"
            style="bottom:0;left:30%;transform:rotate(-3deg);opacity:.25"
        />
        <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
            <span
                class="inline-block bg-primary/10 border border-primary/30 text-primary text-xs font-bold px-4 py-1 rounded-full mb-4 tracking-wider uppercase"
                >Step-by-Step Solar Estimator</span
            >
            <h1
                class="text-4xl sm:text-5xl font-display font-extrabold text-neutral-800 dark:text-white leading-tight mb-3"
            >
                How Much Will You <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-cyan-500"
                    >Save Going Solar?</span
                >
            </h1>
            <p class="text-neutral-500 text-base max-w-lg mx-auto">
                Fill the 4 steps below and instantly get your personalised solar
                savings report with charts.
            </p>
        </div>
    </section>

    <!-- ROADMAP WIZARD -->
    <section
        class="bg-neutral-100 dark:bg-neutral-900 py-14 px-4 sm:px-6 relative overflow-hidden"
    >
        <!-- floating images (random positions) -->
        <img
            src="https://images.unsplash.com/photo-1548337138-e87d889cc369?w=220&q=55&fit=crop"
            alt=""
            class="float-img"
            style="top:3%;right:1%"
        />
        <img
            src="https://images.unsplash.com/photo-1592833159155-c62df1b65634?w=200&q=55&fit=crop"
            alt=""
            class="float-img"
            style="top:40%;left:-30px;transform:rotate(8deg)"
        />
        <img
            src="https://images.unsplash.com/photo-1532601224476-15c79f2f7a51?w=200&q=55&fit=crop"
            alt=""
            class="float-img"
            style="bottom:8%;right:0"
        />

        <div class="max-w-3xl mx-auto relative z-10">
            <!-- PROGRESS BAR -->
            <div
                class="flex items-center justify-center gap-0 mb-12 select-none"
                id="roadmap"
            >
                {
                    [
                        { n: 1, label: "Property" },
                        { n: 2, label: "Location" },
                        { n: 3, label: "Electricity" },
                        { n: 4, label: "Rooftop" },
                    ].map((s, i) => (
                        <div class="flex items-center">
                            <div
                                class={`step-node ${i === 0 ? "active" : ""}`}
                                id={`node-${s.n}`}
                                data-step={s.n}
                            >
                                <span class="step-number">{s.n}</span>
                                <span class="step-label">{s.label}</span>
                            </div>
                            {i < 3 && (
                                <div class="step-line" id={`line-${s.n}`} />
                            )}
                        </div>
                    ))
                }
            </div>

            <!-- STEP 1 – Property Type -->
            <div class="wizard-step active" id="step-1">
                <div class="step-card">
                    <div class="step-heading">
                        <svg
                            class="step-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
                            ></path></svg
                        >
                        Select Your Property Type
                    </div>
                    <div class="grid grid-cols-3 gap-4 mt-5" id="propGroup">
                        <button
                            type="button"
                            data-val="industrial"
                            class="prop-card active"
                            id="pc-industrial"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                class="prop-svg"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"
                                ></path></svg
                            >
                            <span>Industrial</span>
                        </button>
                        <button
                            type="button"
                            data-val="commercial"
                            class="prop-card"
                            id="pc-commercial"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                class="prop-svg"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
                                ></path></svg
                            >
                            <span>Commercial</span>
                        </button>
                        <button
                            type="button"
                            data-val="residential"
                            class="prop-card"
                            id="pc-residential"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                class="prop-svg"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                                ></path></svg
                            >
                            <span>Residential</span>
                        </button>
                    </div>
                    <div class="step-nav">
                        <button type="button" class="btn-next" onclick="goto(2)"
                            >Next: Location
                            <svg
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>
            </div>

            <!-- STEP 2 – Location -->
            <div class="wizard-step" id="step-2">
                <div class="step-card">
                    <div class="step-heading">
                        <svg
                            class="step-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"
                            ></path></svg
                        >
                        Your Location
                    </div>
                    <p
                        class="text-xs text-neutral-500 dark:text-neutral-400 mb-4"
                    >
                        Used to estimate local solar irradiance for accurate
                        output calculations.
                    </p>
                    <div class="flex gap-2">
                        <div class="relative flex-1">
                            <input
                                type="text"
                                id="locationInput"
                                placeholder="Enter city or state..."
                                class="loc-input"
                            />
                            <svg
                                class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"
                                ></path></svg
                            >
                        </div>
                        <button
                            type="button"
                            id="geoBtn"
                            class="geo-btn"
                            onclick="getLocation()"
                        >
                            <svg
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><circle cx="12" cy="12" r="3"></circle><path
                                    stroke-linecap="round"
                                    d="M12 2v3m0 14v3M2 12h3m14 0h3"
                                ></path></svg
                            >
                            Get Location
                        </button>
                    </div>
                    <p
                        id="geoStatus"
                        class="text-xs mt-2 text-neutral-400 min-h-[16px]"
                    >
                    </p>

                    <!-- State selector -->
                    <div class="mt-4">
                        <label class="field-label block mb-1" for="stateSelect"
                            >State / UT</label
                        >
                        <select
                            id="stateSelect"
                            onchange="onStateChange()"
                            class="loc-input cursor-pointer"
                        >
                            <option value="">-- Select your state --</option>
                            <option>Andhra Pradesh</option><option
                                >Arunachal Pradesh</option
                            >
                            <option>Assam</option><option>Bihar</option>
                            <option>Chhattisgarh</option><option>Delhi</option>
                            <option>Goa</option><option>Gujarat</option>
                            <option>Haryana</option><option
                                >Himachal Pradesh</option
                            >
                            <option>Jharkhand</option><option>Karnataka</option>
                            <option>Kerala</option><option
                                >Madhya Pradesh</option
                            >
                            <option>Maharashtra</option><option>Manipur</option>
                            <option>Meghalaya</option><option>Mizoram</option>
                            <option>Nagaland</option><option>Odisha</option>
                            <option>Punjab</option><option>Rajasthan</option>
                            <option>Sikkim</option><option>Tamil Nadu</option>
                            <option>Telangana</option><option>Tripura</option>
                            <option>Uttar Pradesh</option><option
                                >Uttarakhand</option
                            >
                            <option>West Bengal</option>
                        </select>
                        <p
                            id="tariffPreview"
                            class="text-xs text-primary font-semibold mt-1.5 min-h-[16px]"
                        >
                        </p>
                    </div>

                    <div class="step-nav">
                        <button type="button" class="btn-back" onclick="goto(1)"
                            >Back</button
                        >
                        <button type="button" class="btn-next" onclick="goto(3)"
                            >Next: Electricity
                            <svg
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>
            </div>

            <!-- STEP 3 – Electricity -->
            <div class="wizard-step" id="step-3">
                <div class="step-card">
                    <div class="step-heading">
                        <svg
                            class="step-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                            ></path></svg
                        >
                        Electricity Usage
                    </div>

                    <!-- Tariff info box -->
                    <div
                        id="tariffBox"
                        class="mt-4 rounded-xl border border-primary/30 bg-primary/5 px-4 py-3 hidden"
                    >
                        <div
                            class="flex justify-between items-center gap-3 flex-wrap"
                        >
                            <div>
                                <p
                                    class="text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-0.5"
                                    id="tariffStateLabel"
                                >
                                    State Tariff
                                </p>
                                <p
                                    class="text-sm font-bold text-primary"
                                    id="tariffRange"
                                >
                                    —
                                </p>
                            </div>
                            <div class="flex items-center gap-2">
                                <label class="text-xs text-neutral-500"
                                    >Effective ₹/unit</label
                                >
                                <input
                                    type="number"
                                    id="tariffInput"
                                    min="0.5"
                                    max="25"
                                    step="0.05"
                                    value="6.00"
                                    class="w-20 text-center text-sm font-bold text-primary bg-white dark:bg-neutral-700 border border-primary/40 rounded-lg px-2 py-1 focus:outline-none focus:border-primary"
                                    oninput="onTariffOverride()"
                                />
                            </div>
                        </div>
                        <p class="text-xs text-neutral-400 mt-1.5">
                            Bill = Units × Effective Rate. You can override the
                            rate above.
                        </p>
                    </div>

                    <div class="space-y-6 mt-4">
                        <!-- Units -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="field-label" for="unitsSlider"
                                    ><span class="req">*</span> Avg. Units / Month</label
                                >
                                <div class="flex items-center gap-1">
                                    <input
                                        type="number"
                                        id="unitsInput"
                                        value="2000"
                                        min="0"
                                        max="40000"
                                        class="val-input"
                                    />
                                    <span class="text-xs text-neutral-500"
                                        >Units</span
                                    >
                                </div>
                            </div>
                            <input
                                type="range"
                                id="unitsSlider"
                                min="0"
                                max="40000"
                                step="50"
                                value="2000"
                                class="calc-slider"
                            />
                            <div class="range-labels">
                                <span>0</span><span>40,000</span>
                            </div>
                        </div>
                        <!-- Bill (auto or manual) -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="field-label" for="billSlider">
                                    <span class="req">*</span> Monthly Bill (Rs.)
                                    <span
                                        id="billAutoTag"
                                        class="ml-1 text-[10px] font-bold text-emerald-500 hidden"
                                        >(auto)</span
                                    >
                                </label>
                                <div class="flex items-center gap-1">
                                    <span class="text-xs text-neutral-500"
                                        >Rs.</span
                                    >
                                    <input
                                        type="number"
                                        id="billInput"
                                        value="45000"
                                        min="0"
                                        max="500000"
                                        class="val-input"
                                    />
                                    <span class="text-xs text-neutral-500"
                                        >/mo</span
                                    >
                                </div>
                            </div>
                            <input
                                type="range"
                                id="billSlider"
                                min="0"
                                max="500000"
                                step="500"
                                value="45000"
                                class="calc-slider"
                            />
                            <div class="range-labels">
                                <span>Rs. 0</span><span>Rs. 5L</span>
                            </div>
                        </div>
                    </div>
                    <div class="step-nav">
                        <button type="button" class="btn-back" onclick="goto(2)"
                            >Back</button
                        >
                        <button type="button" class="btn-next" onclick="goto(4)"
                            >Next: Rooftop
                            <svg
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>
            </div>

            <!-- STEP 4 – Rooftop -->
            <div class="wizard-step" id="step-4">
                <div class="step-card">
                    <div class="step-heading">
                        <svg
                            class="step-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 0 1-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-2.25z"
                            ></path></svg
                        >
                        Rooftop Area
                    </div>
                    <div class="mt-4">
                        <div class="flex justify-between items-center mb-1">
                            <label class="field-label" for="areaSlider"
                                ><span class="req">*</span> Available Area (Sq. Ft.)</label
                            >
                            <div class="flex items-center gap-1">
                                <input
                                    type="number"
                                    id="areaInput"
                                    value="5000"
                                    min="0"
                                    max="100000"
                                    class="val-input"
                                />
                                <span class="text-xs text-neutral-500"
                                    >Sq.Ft.</span
                                >
                            </div>
                        </div>
                        <input
                            type="range"
                            id="areaSlider"
                            min="0"
                            max="100000"
                            step="100"
                            value="5000"
                            class="calc-slider"
                        />
                        <div class="range-labels">
                            <span>0</span><span>1,00,000</span>
                        </div>
                    </div>
                    <div class="step-nav">
                        <button type="button" class="btn-back" onclick="goto(3)"
                            >Back</button
                        >
                        <button
                            type="button"
                            class="btn-calculate"
                            onclick="showResults()"
                        >
                            <svg
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"
                                ></path></svg
                            >
                            Calculate My Savings
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- RESULTS -->
    <section
        id="results"
        class="hidden bg-neutral-200 dark:bg-neutral-800 py-14 px-4 sm:px-6"
    >
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <h2
                    class="text-3xl font-display font-bold text-neutral-800 dark:text-white mb-1"
                >
                    Your Solar <span class="text-primary">Savings Report</span>
                </h2>
                <p
                    class="text-neutral-500 dark:text-neutral-400 text-sm"
                    id="resultsSubtitle"
                >
                </p>
            </div>

            <!-- KPI CARDS -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
                <div class="kpi-card border-primary/40">
                    <svg
                        class="kpi-icon text-primary"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                        ></path></svg
                    >
                    <p class="kpi-label">System Size</p>
                    <p class="kpi-value text-primary" id="r-size">—</p>
                </div>
                <div class="kpi-card border-amber-400/40">
                    <svg
                        class="kpi-icon text-amber-500"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0z"
