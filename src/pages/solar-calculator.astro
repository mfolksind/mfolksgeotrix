        "Tamil Nadu": {
            residential: [4.5, 11.05],
            commercial: [8.25, 10.0],
            industrial: [6.0, 8.0],
        },
        Telangana: {
            residential: [1.45, 7.5],
            commercial: [7.5, 9.5],
            industrial: [7.0, 11.0],
        },
        Tripura: {
            residential: [3.5, 7.0],
            commercial: [6.0, 8.5],
            industrial: [5.5, 7.5],
        },
        "Uttar Pradesh": {
            residential: [3.35, 8.0],
            commercial: [7.0, 10.0],
            industrial: [6.9, 10.0],
        },
        Uttarakhand: {
            residential: [3.0, 6.5],
            commercial: [5.5, 8.0],
            industrial: [5.0, 7.0],
        },
        "West Bengal": {
            residential: [3.3, 8.5],
            commercial: [7.0, 9.0],
            industrial: [6.0, 8.12],
        },
        Delhi: {
            residential: [0.0, 8.0],
            commercial: [9.0, 10.0],
            industrial: [7.0, 9.0],
        },
    };
    // Nominatim → dropdown name normalization
    const STATE_ALIAS = {
        delhi: "Delhi",
        "national capital territory of delhi": "Delhi",
        "nct of delhi": "Delhi",
        "andhra pradesh": "Andhra Pradesh",
        "arunachal pradesh": "Arunachal Pradesh",
        assam: "Assam",
        bihar: "Bihar",
        chhattisgarh: "Chhattisgarh",
        chandigarh: "Punjab",
        goa: "Goa",
        gujarat: "Gujarat",
        haryana: "Haryana",
        "himachal pradesh": "Himachal Pradesh",
        jharkhand: "Jharkhand",
        karnataka: "Karnataka",
        kerala: "Kerala",
        "madhya pradesh": "Madhya Pradesh",
        maharashtra: "Maharashtra",
        manipur: "Manipur",
        meghalaya: "Meghalaya",
        mizoram: "Mizoram",
        nagaland: "Nagaland",
        odisha: "Odisha",
        orissa: "Odisha",
        punjab: "Punjab",
        rajasthan: "Rajasthan",
        sikkim: "Sikkim",
        "tamil nadu": "Tamil Nadu",
        telangana: "Telangana",
        tripura: "Tripura",
        "uttar pradesh": "Uttar Pradesh",
        uttarakhand: "Uttarakhand",
        uttaranchal: "Uttarakhand",
        "west bengal": "West Bengal",
    };
    // ---- app state ----
    let state = {
        prop: "industrial",
        stateName: "",
        loc: "",
        bill: 45000,
        units: 2000,
        area: 5000,
        tariff: 6.0, // effective ₹/unit
        tariffAuto: false, // is bill auto-derived from tariff?
        years: 25,
    };
    let barChart, donutChart, lineChart;
    const COST_KWP = 42000;
    const UPK = 120;
    const ESC = 0.05;
    const MULT = { industrial: 1.0, commercial: 0.92, residential: 0.85 };

    // ---- tariff helpers ----
    function getTariffRange(stateName, prop) {
        const d = ST[stateName];
        if (!d) return null;
        const key =
            prop === "industrial"
                ? "industrial"
                : prop === "commercial"
                  ? "commercial"
                  : "residential";
        return d[key];
    }
    function midTariff(range) {
        return +((range[0] + range[1]) / 2).toFixed(2);
    }

    function onStateChange() {
        const sel = document.getElementById("stateSelect");
        state.stateName = sel.value;
        const range = getTariffRange(state.stateName, state.prop);
        const box = document.getElementById("tariffBox");
        const prev = document.getElementById("tariffPreview");
        if (range) {
            const mid = midTariff(range);
            state.tariff = mid;
            document.getElementById("tariffInput").value = mid.toFixed(2);
            document.getElementById("tariffStateLabel").textContent =
                state.stateName + " — " + state.prop + " tariff";
            document.getElementById("tariffRange").textContent =
                "₹" +
                range[0].toFixed(2) +
                " – ₹" +
                range[1].toFixed(2) +
                "/unit (mid: ₹" +
                mid.toFixed(2) +
                ")";
            box.classList.remove("hidden");
            prev.textContent =
                "₹" +
                range[0] +
                " – ₹" +
                range[1] +
                "/unit (" +
                state.prop +
                ")";
            autoBill();
        } else {
            box.classList.add("hidden");
            prev.textContent = "";
        }
    }
    function onTariffOverride() {
        const v = parseFloat(document.getElementById("tariffInput").value);
        if (!isNaN(v) && v > 0) {
            state.tariff = v;
            autoBill();
        }
    }
    function autoBill() {
        if (!state.stateName) return;
        const computed = Math.round(state.units * state.tariff);
        const clamped = Math.min(computed, 500000);
        // sync bill slider + input
        const bs = document.getElementById("billSlider");
        const bi = document.getElementById("billInput");
        bs.value = clamped;
        bi.value = clamped;
        bs.style.setProperty("--pct", (clamped / 500000) * 100 + "%");
        state.bill = clamped;
        state.tariffAuto = true;
        document.getElementById("billAutoTag").classList.remove("hidden");
    }

    function fmt(n) {
        if (n >= 10000000) return "\u20b9" + (n / 10000000).toFixed(2) + " Cr";
        if (n >= 100000) return "\u20b9" + (n / 100000).toFixed(2) + " L";
        return "\u20b9" + Math.round(n).toLocaleString("en-IN");
    }
    function goto(n) {
        for (let i = 1; i <= 4; i++) {
            document
                .getElementById("step-" + i)
                .classList.toggle("active", i === n);
            const nd = document.getElementById("node-" + i);
            nd.classList.toggle("active", i === n);
            nd.classList.toggle("done", i < n);
            if (i < 4) {
                const ln = document.getElementById("line-" + i);
                ln.classList.toggle("done", i < n);
            }
        }
    }
    function getLocation() {
        const btn = document.getElementById("geoBtn");
        const status = document.getElementById("geoStatus");
        if (!navigator.geolocation) {
            status.textContent = "Geolocation not supported by your browser.";
            return;
        }
        btn.disabled = true;
        btn.textContent = "Locating...";
        status.textContent = "Fetching your location...";
        navigator.geolocation.getCurrentPosition(
            async (pos) => {
                try {
                    const r = await fetch(
                        `https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`,
                    );
                    const d = await r.json();
                    const city =
                        d.address.city ||
                        d.address.town ||
                        d.address.village ||
                        d.address.county ||
                        "";
                    const rawState = d.address.state || "";
                    const val = [city, rawState].filter(Boolean).join(", ");
                    document.getElementById("locationInput").value = val;
                    state.loc = val;

                    // ── Auto-select state dropdown ──
                    const normalized = rawState.trim().toLowerCase();
                    const matched = STATE_ALIAS[normalized] || null;
                    if (matched) {
                        const sel = document.getElementById("stateSelect");
                        sel.value = matched;
                        onStateChange(); // update tariff box immediately
                        status.textContent = `Location detected: ${val} — tariff loaded for ${matched}`;
                    } else {
                        status.textContent =
                            "Location detected: " +
                            val +
                            " (select state manually for tariff)";
                    }
                } catch (e) {
                    status.textContent =
                        "Could not reverse geocode. Please type manually.";
                }
                btn.disabled = false;
                btn.innerHTML =
                    '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" d="M12 2v3m0 14v3M2 12h3m14 0h3"/></svg> Get Location';
            },
            (err) => {
                status.textContent = "Location denied. Please enter manually.";
                btn.disabled = false;
                btn.innerHTML =
                    '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" d="M12 2v3m0 14v3M2 12h3m14 0h3"/></svg> Get Location';
            },
        );
    }
    function calcResults(years) {
        const m = MULT[state.prop] || 1;
        const kWp = Math.max(1, Math.round((state.units * m) / UPK));
        const cost = kWp * COST_KWP;
        const mOut = kWp * UPK;
        const mSave = Math.min(
            state.bill,
            mOut * (state.bill / Math.max(state.units, 1)),
        );
        let total = 0,
            arr = [];
        for (let y = 1; y <= years; y++) {
            const s = mSave * 12 * Math.pow(1 + ESC, y - 1) - cost * 0.005;
            total += s;
            arr.push({ y, s, cum: total });
        }
        const payback = cost / Math.max(mSave * 12, 1);
        return { kWp, cost, mOut, total, arr, payback };
    }
    function isDark() {
        return document.documentElement.classList.contains("dark");
    }
    function textCol() {
        return isDark() ? "#d1d5db" : "#374151";
    }
    function gridCol() {
        return isDark() ? "#37415155" : "#e5e7eb99";
    }

    function showResults() {
        state.loc = document.getElementById("locationInput").value;
        const r = calcResults(state.years);
        document.getElementById("r-size").textContent = r.kWp + " kWp";
        document.getElementById("r-output").textContent =
            r.mOut.toLocaleString("en-IN") + " units/mo";
        document.getElementById("r-savings").textContent = fmt(r.total);
        document.getElementById("r-payback").textContent =
            r.payback.toFixed(1) + " yrs";
        document.getElementById("r-cost").textContent = fmt(r.cost);
        const loc = state.loc ? ` for ${state.loc}` : "";
        document.getElementById("resultsSubtitle").textContent =
            `${state.prop.charAt(0).toUpperCase() + state.prop.slice(1)} property${loc} — ${state.years}-year projection`;
        document.getElementById("results").classList.remove("hidden");
        document
            .getElementById("results")
            .scrollIntoView({ behavior: "smooth" });
        renderCharts(r);
    }
    function renderCharts(r) {
        const labels = r.arr.map((x) => "Yr " + x.y);
        const savings = r.arr.map((x) => Math.round(x.s / 1000));
        const cum = r.arr.map((x) => Math.round(x.cum / 1000));
        const costK = Math.round(r.cost / 1000);
        const net25K = Math.round(r.total / 1000);
        const baseOpts = {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: (c) =>
                            "\u20b9" + c.parsed.y.toLocaleString("en-IN") + "K",
                    },
                },
            },
        };

        // Bar
        const bCtx = document.getElementById("barChart").getContext("2d");
        if (barChart) barChart.destroy();
        barChart = new Chart(bCtx, {
            type: "bar",
            data: {
                labels,
                datasets: [
                    {
                        label: "Annual Savings",
                        data: savings,
                        backgroundColor: "#50c1c8cc",
                        borderRadius: 6,
                        hoverBackgroundColor: "#50c1c8",
                    },
                ],
            },
            options: {
                ...baseOpts,
                scales: {
                    x: {
                        ticks: { color: textCol(), font: { size: 10 } },
                        grid: { color: gridCol() },
                    },
                    y: {
                        ticks: {
                            color: textCol(),
                            callback: (v) => "\u20b9" + v + "K",
                        },
                        grid: { color: gridCol() },
                    },
                },
            },
        });

        // Donut
        const dCtx = document.getElementById("donutChart").getContext("2d");
        if (donutChart) donutChart.destroy();
        donutChart = new Chart(dCtx, {
            type: "doughnut",
            data: {
                labels: ["System Cost", "Net Savings"],
                datasets: [
                    {
                        data: [costK < 0 ? 0 : costK, net25K < 0 ? 0 : net25K],
                        backgroundColor: ["#50c1c8", "#10b981"],
                        borderWidth: 0,
                        hoverOffset: 8,
                    },
                ],
            },
            options: {
                responsive: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: (c) =>
                                c.label +
                                ": \u20b9" +
                                c.raw.toLocaleString("en-IN") +
                                "K",
                        },
                    },
                },
                cutout: "68%",
            },
        });

        // Line
        const lCtx = document.getElementById("lineChart").getContext("2d");
        if (lineChart) lineChart.destroy();
        const grad = lCtx.createLinearGradient(0, 0, 0, 200);
        grad.addColorStop(0, "#50c1c840");
        grad.addColorStop(1, "#50c1c800");
        lineChart = new Chart(lCtx, {
            type: "line",
            data: {
                labels,
                datasets: [
                    {
                        label: "Cumulative Savings",
                        data: cum,
                        borderColor: "#50c1c8",
                        backgroundColor: grad,
                        borderWidth: 2.5,
                        pointRadius: 3,
                        pointBackgroundColor: "#50c1c8",
                        fill: true,
                        tension: 0.35,
                    },
                ],
            },
            options: {
                ...baseOpts,
                plugins: {
                    ...baseOpts.plugins,
                    tooltip: {
                        callbacks: {
                            label: (c) =>
                                "\u20b9" +
                                c.parsed.y.toLocaleString("en-IN") +
                                "K",
                        },
                    },
                },
                scales: {
                    x: {
                        ticks: { color: textCol(), font: { size: 10 } },
                        grid: { color: gridCol() },
                    },
                    y: {
                        ticks: {
                            color: textCol(),
                            callback: (v) => "\u20b9" + v + "K",
                        },
                        grid: { color: gridCol() },
                    },
                },
            },
        });
    }
    function resetCalc() {
        document.getElementById("results").classList.add("hidden");
        goto(1);
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    // ---- slider sync ----
    function bindSlider(sliderId, inputId, setter) {
        const s = document.getElementById(sliderId),
            i = document.getElementById(inputId);
        const sync = (v) => {
            const c = Math.max(+s.min, Math.min(+s.max, v));
            s.value = c;
            i.value = c;
            s.style.setProperty(
                "--pct",
                ((c - +s.min) / (+s.max - +s.min)) * 100 + "%",
            );
            setter(c);
        };
        s.addEventListener("input", () => sync(+s.value));
        i.addEventListener("input", () => sync(+i.value));
        sync(+s.value);
    }
    bindSlider("billSlider", "billInput", (v) => {
        state.bill = v;
        state.tariffAuto = false;
        document.getElementById("billAutoTag").classList.add("hidden");
    });
    bindSlider("unitsSlider", "unitsInput", (v) => {
        state.units = v;
        autoBill();
    });
    bindSlider("areaSlider", "areaInput", (v) => (state.area = v));

    // property type
    document.getElementById("propGroup").addEventListener("click", (e) => {
        const b = e.target.closest("[data-val]");
        if (!b) return;
        state.prop = b.dataset.val;
        document
            .querySelectorAll(".prop-card")
            .forEach((c) => c.classList.remove("active"));
        b.classList.add("active");
        // Refresh tariff when property type changes
        if (state.stateName) onStateChange();
    });

    // location input
    document
        .getElementById("locationInput")
        .addEventListener("input", (e) => (state.loc = e.target.value));

    // year selector
    document.getElementById("yrGroup").addEventListener("click", (e) => {
        const b = e.target.closest("[data-yr]");
        if (!b) return;
        state.years = +b.dataset.yr;
        document
            .querySelectorAll(".yr-btn")
            .forEach((x) => x.classList.remove("active"));
        b.classList.add("active");
        const r = calcResults(state.years);
        document.getElementById("r-savings").textContent = fmt(r.total);
        const loc = state.loc ? ` for ${state.loc}` : "";
        document.getElementById("resultsSubtitle").textContent =
            `${state.prop.charAt(0).toUpperCase() + state.prop.slice(1)} property${loc} — ${state.years}-year projection`;
        renderCharts(r);
    });
</script>
