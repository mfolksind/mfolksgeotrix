---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants";

const pageTitle: string = `Contact Us | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/contact-us`,
    "url": `${SITE.url}/contact-us`,
    "name": `Contact Us | ${SITE.title}`,
    "description":
      "Have questions or want to discuss an earthing or lightning protection project? Reach out, and let's craft the perfect solution with our expertise.",
    "isPartOf": {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.title
    },
    "inLanguage": "en-US"
  }}
>
  <ContactSection />
</MainLayout>
