---
// Import components
import MainLayout from "@layouts/MainLayout.astro";
import ProductTabBtn from "@components/ui/buttons/ProductTabBtn.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import { Image } from "astro:assets";
import { wpFetch, ALL_PRODUCTS_QUERY, PRODUCT_BY_SLUG_QUERY } from "@lib/wp";
import { SITE } from "@data/constants";
import ProductDetailClient from "@components/products/ProductDetailClient";
import ProductCarousel from "@components/products/ProductCarousel.astro";

// Global declaration for gsap
declare global {
  interface Window {
    gsap: any;
  }
}

// Get static paths from WordPress
export async function getStaticPaths() {
  const data = await wpFetch(ALL_PRODUCTS_QUERY);
  const products = data?.products?.nodes || [];

  return products.map((product: any) => ({
    params: { slug: product.slug },
    props: { productSlug: product.slug },
  }));
}

const { productSlug } = Astro.props;

// Fetch full product data
const data = await wpFetch(PRODUCT_BY_SLUG_QUERY, { slug: productSlug });
const product = data?.product;

if (!product) {
  return Astro.redirect("/404");
}

// Dynamic SEO using Rank Math / Yoast template format
const pageTitle = `${product.title} Supplier in India | ${SITE.title}`;
const metaDescription = `Manufacturer and supplier of ${product.title} in India. Pan-India delivery for industrial, solar, data center, and infrastructure projects.`;
const ogTitle = `${product.title} Supplier in India | MFOLKS Geotrix`;

// Define tabs for product detail page
const tabs = [
  {
    title: "Overview",
    id: "tabs-with-card-item-1",
    dataTab: "#tabs-with-card-1",
  },
  {
    title: "Specifications",
    id: "tabs-with-card-item-2",
    dataTab: "#tabs-with-card-2",
  },
  {
    title: "Variants & Pricing",
    id: "tabs-with-card-item-3",
    dataTab: "#tabs-with-card-3",
  },
];

// ========================================
// 🚀 DYNAMIC SCHEMA GENERATION FOR GOOGLE
// ========================================
// Extract variant prices and calculate price range
const variants = product.productData?.productVariants || [];
const prices = variants
  .map((v: any) => (v.variantPrice ? parseFloat(String(v.variantPrice)) : null))
  .filter((p: number | null) => p !== null && !isNaN(p) && p > 0) as number[];

// Determine availability based on variants
// Handle both array format from WordPress and string format from mock data
const hasInStockVariants = variants.some((v: any) => {
  const availability = Array.isArray(v.availability)
    ? v.availability[0]
    : v.availability;
  return availability === "in_stock" || availability === "standard";
});
const availabilityStatus = hasInStockVariants
  ? "https://schema.org/InStock"
  : "https://schema.org/PreOrder";

// Build structured data with proper offers
let structuredData: any = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${SITE.url}/${product.slug}`,
  name: product.title,
  description: metaDescription,
  brand: {
    "@type": "Brand",
    name: "MFOLKS Geotrix",
  },
  url: `${SITE.url}/${product.slug}`,
};

// Add image if available
if (product.featuredImage?.node?.sourceUrl) {
  structuredData.image = product.featuredImage.node.sourceUrl;
}

// Add SKU from first variant if available
if (variants.length > 0 && variants[0].variantSku) {
  structuredData.sku = variants[0].variantSku;
}

// ✅ ADD OFFERS (Required by Google)
if (prices.length > 0) {
  const lowPrice = Math.min(...prices);
  const highPrice = Math.max(...prices);

  structuredData.offers = {
    "@type": "AggregateOffer",
    priceCurrency: "INR",
    lowPrice: String(lowPrice),
    highPrice: String(highPrice),
    offerCount: String(variants.length),
    availability: availabilityStatus,
    url: `${SITE.url}/${product.slug}`,
  };
} else {
  //  Fallback for products without pricing (configurable/POA)
  // Use simple Offer to satisfy Google's requirement
  structuredData.offers = {
    "@type": "Offer",
    priceCurrency: "INR",
    price: "0",
    availability: availabilityStatus,
    url: `${SITE.url}/${product.slug}`,
    priceValidUntil: new Date(new Date().getFullYear() + 1, 11, 31)
      .toISOString()
      .split("T")[0],
  };
}
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredImage={product.featuredImage?.node?.sourceUrl}
  structuredData={structuredData}
>
  <div
    id="overlay"
    class="fixed inset-0 bg-neutral-200 dark:bg-neutral-800 z-50 transition-opacity duration-500"
  >
  </div>

  <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid lg:grid-cols-3 gap-8 xl:gap-12 items-start">
      {/* Left Column - Product Image & Details */}
      <div class="lg:col-span-2 space-y-10 mt-10">
        {/* Header & Image */}
        <div class="space-y-6">
          <div class="space-y-2" id="fadeInUp">
            <span
              class="text-orange-500 font-bold uppercase tracking-wider text-sm"
            >
              {
                (product.productCategories?.nodes || [])
                  .map((cat: any) => cat.name)
                  .join(" • ")
              }
            </span>
            <h1
              class="text-3xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 leading-tight"
            >
              {product.title}
            </h1>
            <p
              id="fadeText"
              class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl"
            >
              {product.productData?.shortDescription}
            </p>
          </div>

          <div
            id="imageContainer"
            class="bg-white dark:bg-neutral-900 rounded-3xl overflow-hidden border border-neutral-200 dark:border-neutral-700 aspect-square max-w-lg flex items-center justify-center relative group shadow-sm"
          >
            <div
              class="absolute inset-0 bg-gradient-to-tr from-neutral-100/50 via-transparent to-transparent dark:from-neutral-800/50 opacity-100"
            >
            </div>
            {
              product.featuredImage?.node?.sourceUrl ? (
                <img
                  src={product.featuredImage.node.sourceUrl}
                  class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-110 relative z-10"
                  alt={product.featuredImage.node.altText || product.title}
                  loading="eager"
                />
              ) : (
                <div class="text-neutral-400 flex flex-col items-center relative z-10">
                  <svg
                    width="64"
                    height="64"
                    viewBox="0 0 24 24"
                    fill="none"
                    class="opacity-50"
                    stroke="currentColor"
                    stroke-width="1"
                  >
                    <>
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                      <circle cx="9" cy="9" r="2" />
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                    </>
                  </svg>
                </div>
              )
            }
          </div>
        </div>

        <div class="h-px bg-neutral-200 dark:bg-neutral-800"></div>

        {/* Info Tabs */}
        <div class="space-y-6">
          <div
            class="border-b border-neutral-200 dark:border-neutral-700 flex gap-8"
            id="info-tabs"
          >
            <button
              class="pb-3 border-b-2 border-orange-500 text-orange-600 dark:text-orange-500 font-bold text-sm uppercase tracking-wide transition-colors"
              data-target="#content-benefits"
            >
              Key Benefits
            </button>
            <button
              class="pb-3 border-b-2 border-transparent text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200 font-bold text-sm uppercase tracking-wide transition-colors"
              data-target="#content-specs"
            >
              Specifications
            </button>
          </div>

          <div id="tab-content-area" class="min-h-[300px]">
            {/* Benefits Content */}
            <div
              id="content-benefits"
              class="tab-pane space-y-4 animate-fade-in"
            >
              {
                product.productData?.benefits ? (
                  <div class="grid sm:grid-cols-2 gap-4">
                    {product.productData.benefits.map((benefit: any) => (
                      <div class="flex gap-3">
                        <div class="mt-1 min-w-[20px]">
                          <svg
                            class="h-5 w-5 text-orange-500"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        </div>
                        <p class="text-neutral-600 dark:text-neutral-400 font-medium">
                          {benefit.benefitText}
                        </p>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="text-neutral-500">No specific benefits listed.</p>
                )
              }
            </div>

            {/* Specs Content */}
            <div
              id="content-specs"
              class="tab-pane hidden space-y-4 animate-fade-in"
            >
              {
                product.productData?.technicalSpecs &&
                product.productData.technicalSpecs.length > 0 ? (
                  <div class="border border-neutral-200 dark:border-neutral-700 rounded-xl overflow-hidden">
                    <table class="min-w-full divide-y divide-neutral-200 dark:divide-neutral-700">
                      <tbody class="divide-y divide-neutral-200 dark:divide-neutral-700">
                        {product.productData.technicalSpecs.map((spec: any) => (
                          <tr class="hover:bg-neutral-50 dark:hover:bg-neutral-800/50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-neutral-800 dark:text-neutral-200 w-1/3 bg-neutral-50 dark:bg-neutral-800">
                              {spec.specName}
                            </td>
                            <td class="px-6 py-4 text-sm text-neutral-600 dark:text-neutral-400">
                              {spec.specValue} {spec.specUnit}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                ) : (
                  <p class="text-neutral-500">
                    No technical specifications available.
                  </p>
                )
              }
            </div>
          </div>
        </div>

        {
          product.productData?.applicationsUsedIn && (
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-900/50 rounded-xl p-6">
              <h3 class="font-bold text-blue-900 dark:text-blue-100 mb-2 flex items-center gap-2">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                  />
                </svg>
                Applications
              </h3>
              <p class="text-blue-800 dark:text-blue-200">
                {product.productData.applicationsUsedIn}
              </p>
            </div>
          )
        }

        {/* FAQ Section */}
        {
          product.productData?.productFaqs &&
            product.productData.productFaqs.length > 0 && (
              <div class="space-y-4">
                <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 flex items-center gap-2">
                  <svg
                    class="w-6 h-6 text-orange-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  Frequently Asked Questions
                </h2>
                <div class="space-y-3">
                  {product.productData.productFaqs.map(
                    (faq: any, index: number) => (
                      <div class="border border-neutral-200 dark:border-neutral-700 rounded-xl overflow-hidden faq-item">
                        <button
                          class="w-full px-6 py-4 text-left flex items-center justify-between bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors faq-question"
                          data-faq-index={index}
                        >
                          <span class="font-bold text-neutral-900 dark:text-neutral-100 pr-4">
                            {faq.question}
                          </span>
                          <svg
                            class="w-5 h-5 text-neutral-400 transition-transform faq-icon"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M19 9l-7 7-7-7"
                            />
                          </svg>
                        </button>
                        <div class="faq-answer hidden px-6 py-4 bg-neutral-50 dark:bg-neutral-800/50 border-t border-neutral-200 dark:border-neutral-700">
                          <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
                            {faq.answer}
                          </p>
                        </div>
                      </div>
                    ),
                  )}
                </div>
              </div>
            )
        }
      </div>

      {/* Right Column - Sticky Sidebar */}
      <div class="lg:col-span-1 lg:sticky lg:top-32 space-y-6">
        <div
          class="bg-white dark:bg-neutral-900 rounded-2xl shadow-xl shadow-neutral-200/50 dark:shadow-neutral-900/50 border border-neutral-200 dark:border-neutral-700 p-1 md:p-2 overflow-hidden sticky-pricing-card"
        >
          <ProductDetailClient client:load product={product} />
        </div>

        {/* Support Box */}
        <div
          class="bg-neutral-50 dark:bg-neutral-800 rounded-xl p-6 border border-neutral-200 dark:border-neutral-700 text-center"
        >
          <p class="font-bold text-neutral-900 dark:text-white mb-2">
            Need Technical Support?
          </p>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4">
            Our technical team can help you choose the right configuration for
            your project.
          </p>
          <a
            href="/contact-us"
            class="text-orange-600 dark:text-orange-400 text-sm font-bold hover:underline"
            >Contact Support Team →</a
          >
        </div>
      </div>
    </div>
  </div>

  {/* Related Products Sections */}
  {
    (product.productData?.relatedSystems?.nodes?.length > 0 ||
      product.productData?.compatibleProducts?.nodes?.length > 0 ||
      product.productData?.recommendedProducts?.nodes?.length > 0) && (
      <div class="mx-auto max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14 space-y-12">
        {/* Related Systems */}
        <ProductCarousel
          products={product.productData?.relatedSystems?.nodes}
          variant="orange"
          title="Related Systems"
          icon='<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />'
          badge="System"
          ctaText="View System"
        />

        {/* Compatible Products */}
        <ProductCarousel
          products={product.productData?.compatibleProducts?.nodes}
          variant="blue"
          title="Compatible Products"
          icon='<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />'
          badge="Compatible"
          ctaText="View Details"
        />

        {/* Recommended Products */}
        <ProductCarousel
          products={product.productData?.recommendedProducts?.nodes}
          variant="green"
          title="You May Also Need"
          icon='<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />'
          badge="Recommended"
          ctaText="View Details"
          showGlow={true}
        />
      </div>
    )
  }
</MainLayout>

<script>
  import { gsap } from "gsap";

  type AnimationSettings = {
    autoAlpha?: number;
    y?: number;
    x?: number;
    willChange?: string;
  };

  function setElementAnimationDefaults(
    id: string,
    settings: AnimationSettings,
  ) {
    gsap.set(id, settings);
  }

  // Header & Title Slide Down (Top to Bottom)
  setElementAnimationDefaults("#fadeInUp", {
    autoAlpha: 0,
    y: -30,
    willChange: "transform, opacity",
  });

  // Description Slide Down (Top to Bottom)
  setElementAnimationDefaults("#fadeText", {
    autoAlpha: 0,
    y: -30,
    willChange: "transform, opacity",
  });

  // Image Container Slide In From LEFT (Left to Right)
  setElementAnimationDefaults("#imageContainer", {
    autoAlpha: 0,
    x: -50,
    willChange: "transform, opacity",
  });

  let timeline = gsap.timeline({ defaults: { overwrite: "auto" } });

  // Fade out overlay quickly
  timeline.to("#overlay", { duration: 0.5, autoAlpha: 0 });

  // Animate Header (Down)
  timeline.to(
    "#fadeInUp",
    {
      duration: 0.8,
      autoAlpha: 1,
      y: 0,
      ease: "power3.out",
    },
    "-=0.2",
  );

  // Animate Description (Down) - synced with Header
  timeline.to(
    "#fadeText",
    {
      duration: 0.8,
      autoAlpha: 1,
      y: 0,
      ease: "power3.out",
    },
    "<0.1",
  );

  // Animate Image Container (Left to Right) - synced with Text
  timeline.to(
    "#imageContainer",
    {
      duration: 1.0,
      autoAlpha: 1,
      x: 0,
      ease: "power3.out",
    },
    "<",
  );
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tabButtons = document.querySelectorAll("#info-tabs button");
    const tabPanes = document.querySelectorAll(".tab-pane");

    function activateTab(clickedBtn) {
      // 1. Reset all buttons
      tabButtons.forEach((btn) => {
        btn.classList.remove(
          "border-orange-500",
          "text-orange-600",
          "dark:text-orange-500",
        );
        btn.classList.add(
          "border-transparent",
          "text-neutral-500",
          "hover:text-neutral-800",
          "dark:text-neutral-400",
          "dark:hover:text-neutral-200",
        );
      });

      // 2. Activate clicked button
      clickedBtn.classList.remove(
        "border-transparent",
        "text-neutral-500",
        "hover:text-neutral-800",
        "dark:text-neutral-400",
        "dark:hover:text-neutral-200",
      );
      clickedBtn.classList.add(
        "border-orange-500",
        "text-orange-600",
        "dark:text-orange-500",
      );

      // 3. Show Content
      const targetId = clickedBtn.getAttribute("data-target");
      tabPanes.forEach((pane) => {
        pane.classList.add("hidden");
        if (targetId && pane.id === targetId.substring(1)) {
          pane.classList.remove("hidden");
          // Re-trigger animation if needed
          pane.classList.remove("animate-fade-in");
          void (pane as HTMLElement).offsetWidth; // trigger reflow
          pane.classList.add("animate-fade-in");
        }
      });
    }

    // Attach listeners
    tabButtons.forEach((btn) => {
      btn.addEventListener("click", () => activateTab(btn));
    });

    // FAQ Accordion functionality
    const faqQuestions = document.querySelectorAll(".faq-question");

    faqQuestions.forEach((question) => {
      question.addEventListener("click", function () {
        const faqItem = this.closest(".faq-item");
        const answer = faqItem.querySelector(".faq-answer");
        const icon = this.querySelector(".faq-icon");

        // Toggle answer visibility
        answer.classList.toggle("hidden");

        // Rotate icon
        if (answer.classList.contains("hidden")) {
          icon.style.transform = "rotate(0deg)";
        } else {
          icon.style.transform = "rotate(180deg)";
        }
      });
    });
  });
</script>
