---
import MainLayout from "@layouts/MainLayout.astro";
import CartDisplay from "@components/cart/CartDisplay";
import { SITE } from "@data/constants";

const pageTitle = `Your Cart | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  customDescription="Review your selected earthing and lightning protection products and request a technical quotation."
>
  <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <!-- Header -->
    <div class="max-w-3xl mb-12">
      <h1
        class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4"
      >
        Your Cart
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Review your selected configurations before submitting for a formal technical quotation and lead time estimate.
      </p>
    </div>

    <!-- Cart Display Client Component -->
    <CartDisplay client:load />

    <!-- Additional B2B Info -->
    <div class="mt-20 grid md:grid-cols-2 gap-8">
      <div
        class="bg-neutral-50 dark:bg-neutral-900 border-l-4 border-orange-500 p-8 rounded-r-2xl"
      >
        <h3 class="font-bold text-neutral-900 dark:text-white mb-3 text-lg flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Technical Verification
        </h3>
        <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
          Every quotation request is reviewed by our technical team to ensure the selected components are compatible with your project's soil resistivity and fault load requirements.
        </p>
      </div>

      <div
        class="bg-neutral-50 dark:bg-neutral-900 border-l-4 border-neutral-800 dark:border-neutral-700 p-8 rounded-r-2xl"
      >
        <h3 class="font-bold text-neutral-900 dark:text-white mb-3 text-lg flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Logistics & Delivery
        </h3>
        <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
          For bulk B2B orders, we provide door-to-door logistics across India and handle all export documentation for international shipments (Middle East, Africa, and SE Asia).
        </p>
      </div>
    </div>
  </div>
</MainLayout>
