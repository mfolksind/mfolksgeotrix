---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";

// Import images
import solarPlant from "@images/construction-image.avif";
import industrialMeters from "@images/automated-tools.avif";
import highRise from "@images/progress-building.avif";
import infrastructure from "@images/aerial-view.avif";
import dataCenter from "@images/dashboard-image.avif";
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Solar Power Plants & Renewable Energy",
    subTitle:
      "Utility-scale solar farms require robust DC-side earthing to prevent inverter burnout and fire hazards. We specialize in designing interconnected grounding grids for large acreage sites. \n\nProducts: Copper Bonded Rods, Flat Strips, ESE Lightning Arrestors. \nCompliance: Meets IEC 60364-7-712 and IS 3043 standards for PV safety.",
    single: true,
    imgOne: solarPlant,
    imgOneAlt: "Solar farm grounding grid and lightning protection.",
  },
  {
    isRightSection: false,
    title: "Industrial Plants & Manufacturing",
    subTitle:
      "Heavy machinery and VFDs generate significant electrical noise and fault currents. Our maintenance-free chemical earthing systems ensure low resistance (<1 Ohm) even in corrosive industrial soils, protecting PLC automation and ensuring worker safety during fault conditions. \n\nProducts: Chemical Earthing Electrodes, Earth Enhancement Compounds (BFC).",
    img: industrialMeters,
    imgAlt: "Industrial earthing for heavy machinery and automation.",
    btnExists: true,
    btnTitle: "View Industrial Products",
    btnURL: "/products",
  },
  {
    isRightSection: true,
    title: "Infrastructure & Railways",
    subTitle:
      "From metro rail signaling to highway lighting, public infrastructure demands durability. Our heavy-duty copper bonded rods are designed to withstand high mechanical stress and resist corrosion for 50+ years, ensuring uninterruptible service for critical transport networks. \n\nUse Case: Trackside signaling grounding, OHE mast protection.",
    single: true,
    imgOne: infrastructure,
    imgOneAlt: "Railway signaling and OHE mast earthing connection.",
  },
  {
    isRightSection: false,
    title: "Data Centers & IT Parks",
    subTitle:
      "Mission-critical servers cannot afford downtime or data corruption caused by EMI/RFI interference. We design high-density Signal Reference Grids (SRG) and clean earth systems that provide an equipotential plane for sensitive electronics. \n\nSafety: Zero-noise grounding preventing voltage fluctuation damage.",
    img: dataCenter,
    imgAlt: "Clean earth system for data center server racks.",
  },
  {
    isRightSection: true,
    title: "Commercial & High-Rise Buildings",
    subTitle:
      "Modern architectural esthetics shouldn't compromise safety. Our Advance Early Streamer Emission (ESE) Lightning Arrestors offer a large radius of protection (up to 107m) with a single aesthetically integrated terminal, replacing unsightly mesh cages. \n\nCompliance: NBC 2016 and IEC 62305 protection levels.",
    single: true,
    imgOne: highRise,
    imgOneAlt: "ESE Lightning protection for high-rise commercial tower.",
    btnExists: true,
    btnTitle: "Get Building Compliance Check",
    btnURL: "/contact-us",
  },
];

const pageTitle: string = `Applications | ${SITE.title}`;
const metaDescription =
  "MFOLKS Geotrix provides specialized earthing and lightning protection for solar plants, industrial facilities, high-rise buildings, and mission-critical infrastructure.";
const ogTitle = "Industry Applications | MFOLKS Geotrix";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/applications`,
    url: `${SITE.url}/applications`,
    name: "Earthing Applications by Industry | MFOLKS Geotrix",
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
    },
    inLanguage: "en-US",
  }}
>
  <MainSection
    title="Industry-Specific Earthing & Lightning Protection"
    subTitle="Critical infrastructure demands sector-specific safety solutions. From the high-voltage risks of solar farms to the sensitive electronics of data centers, MFOLKS Geotrix delivers compliant systems tailored to your industries unique electrical and environmental challenges."
    btnExists={true}
    btnTitle="Consult Our Experts"
    btnURL="/contact-us"
  />

  {
    articles.map((article) => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt || "Article image"}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt || "Article image"}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt || "Article image"}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Sector-Wide Expertise"
    subTitle="Trusted by India's leading EPCs and government bodies for projects where failure is not an option."
    mainStatTitle="1000+"
    mainStatSubTitle="site surveys and soil resistivity tests conducted globally"
    stats={[
      {
        stat: "100%",
        description: "Approval rate by PWD/CPWD",
      },
      {
        stat: "IS 3043",
        description: "Fully compliant system designs",
      },
      {
        stat: "25k+",
        description: "Units manufactured monthly",
      },
    ]}
  />
</MainLayout>
